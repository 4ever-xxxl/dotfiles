# ============================================================================
# Env Local
# ============================================================================
if [ -f "$HOME/.env.local" ]; then
    . "$HOME/.env.local"
fi

# =============================================================================
# Proxy Settings
# =============================================================================
if [[ -n "${PROXY_HOST}" && -n "${PROXY_PORT}" ]]; then
    export http_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
    export https_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
    export all_proxy="socks5://${PROXY_HOST}:${PROXY_PORT}"
    export no_proxy="${PROXY_NO_PROXY:-localhost,127.0.0.1,::1,*.local}"
fi

# =============================================================================
# PATH
# =============================================================================
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"
export PATH="$PATH:/opt/riscv/bin"
export PATH="$PATH:/opt/oss-cad-suite/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$HOME/.pixi/bin"
export PATH="$PATH:$HOME/.cargo/bin"
export PATH="$PATH:$HOME/.local/share/coursier/bin"

export GOPATH=$HOME/.local/share/go
export PATH=$PATH:$GOPATH/bin

export CUDA_HOME=/usr/local/cuda
export PATH=$CUDA_HOME/bin:$PATH
export LD_LIBRARY_PATH=$CUDA_HOME/lib64:$LD_LIBRARY_PATH

# =============================================================================
# Mirror
# =============================================================================
export NODE_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/nodejs-release/
export GO111MODULE=on
export GOPROXY=https://goproxy.cn,direct

# =============================================================================
# Tooling Paths
# =============================================================================
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
    export PATH="$FNM_PATH:$PATH"
fi

[ -f "$HOME/.ghcup/env" ] && . "$HOME/.ghcup/env" # ghcup-env

# SDKMAN
export SDKMAN_DIR="$HOME/.sdkman"
[[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]] && source "$SDKMAN_DIR/bin/sdkman-init.sh"

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

# =============================================================================
# Interactive Shell Helpers
# Keep shell-specific functions, aliases, hooks, and completions behind an
# interactive-shell guard so fish can safely import this file through bass.
# =============================================================================
_DOTFILES_SHELL_INTERACTIVE=false
case $- in
    *i*) _DOTFILES_SHELL_INTERACTIVE=true ;;
esac

if [ "$_DOTFILES_SHELL_INTERACTIVE" = "true" ]; then
    # 设置代理的函数
    set_proxy() {
        export http_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
        export https_proxy="http://${PROXY_HOST}:${PROXY_PORT}"
        export all_proxy="socks5://${PROXY_HOST}:${PROXY_PORT}"
        export no_proxy="${PROXY_NO_PROXY:-localhost,127.0.0.1,::1,*.local}"
        echo "Proxy has been set."
    }

    # 取消代理的函数
    unset_proxy() {
        unset http_proxy
        unset https_proxy
        unset all_proxy
        unset no_proxy
        echo "Proxy has been unset."
    }

    # =============================================================================
    # Alias
    # =============================================================================
    alias nv="nvim"
    alias ls="eza"
    alias lg="lazygit"
    alias ps="procs"
    alias du="dust"
    if command -v batcat >/dev/null 2>&1; then
        alias cat="batcat"
    elif command -v bat >/dev/null 2>&1; then
        alias cat="bat"
    fi

    # 文件操作
    alias ll='ls -lah'
    alias la='ls -la'
    alias l='ls -l'
    alias mkdir='mkdir -p'
    alias cp='cp -i'
    alias mv='mv -i'
    alias rm='rm -i'

    # 开发导航
    alias nvim-config='cd ~/.config/nvim'
    alias dotfiles='cd ~/dotfiles'
    alias python='python3'

    # Git 快捷
    alias gs='git status'
    alias ga='git add'
    alias gc='git commit'
    alias gp='git push'
    alias gl='git log --oneline -10'

    man() {
        LESS_TERMCAP_md=$'\e[01;31m' \
        LESS_TERMCAP_me=$'\e[0m' \
        LESS_TERMCAP_se=$'\e[0m' \
        LESS_TERMCAP_so=$'\e[01;44;33m' \
        LESS_TERMCAP_ue=$'\e[0m' \
        LESS_TERMCAP_us=$'\e[01;32m' \
        command man "$@"
    }

    if command -v fnm >/dev/null 2>&1; then
        eval "$(fnm env --use-on-cd)"
    fi

    # ~/.bun/_bun is a zsh completion file, not a shared shell init script.
    if [ -n "${ZSH_VERSION:-}" ] && [ -s "$HOME/.bun/_bun" ]; then
        source "$HOME/.bun/_bun"
    fi
fi

unset _DOTFILES_SHELL_INTERACTIVE
