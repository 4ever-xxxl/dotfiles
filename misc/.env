# =============================================================================
# Proxy Settings
# =============================================================================
proxy_port="7897"
host_ip="127.0.0.1"
export http_proxy="http://${host_ip}:${proxy_port}"
export https_proxy="http://${host_ip}:${proxy_port}"
export all_proxy="socks5://${host_ip}:${proxy_port}"
export no_proxy="localhost,127.0.0.1,*.local"

# 设置代理的函数
set_proxy() {
    export http_proxy="http://${host_ip}:${proxy_port}"
    export https_proxy="http://${host_ip}:${proxy_port}"
    export all_proxy="socks5://${host_ip}:${proxy_port}"
    export no_proxy="localhost,127.0.0.1,*.local" 
    echo "Proxy has been set."
}

# 取消代理的函数
unset_proxy() {
    unset http_proxy
    unset https_proxy
    unset all_proxy
    unset no_proxy
    echo "Proxy has been unset."
}

# =============================================================================
# PATH
# =============================================================================
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"
export PATH="$PATH:/opt/riscv/bin"
export PATH="$PATH:/opt/oss-cad-suite/bin"
export PATH="$PATH:$HOME/.local/bin"
export PATH="$PATH:$HOME/.pixi/bin"
export PATH="$PATH:$HOME/.local/share/coursier/bin"

export GOPATH=$HOME/.local/share/go
export PATH=$PATH:$GOPATH/bin

export CUDA_HOME=/usr/local/cuda
export PATH=$CUDA_HOME/bin:$PATH
export LD_LIBRARY_PATH=$CUDA_HOME/lib64:$LD_LIBRARY_PATH

# =============================================================================
# Claude
# =============================================================================
export ANTHROPIC_BASE_URL="https://api.siliconflow.cn/"
export ANTHROPIC_MODEL="Pro/moonshotai/Kimi-K2.5"

# Load local environment variables (keys, etc.)
if [ -f "$HOME/.env.local" ]; then
    . "$HOME/.env.local"
fi

# =============================================================================
# Alias
# =============================================================================
alias nv="nvim"
alias ls="eza"
alias lg="lazygit"
if command -v batcat >/dev/null 2>&1; then
    alias cat="batcat"
elif command -v bat >/dev/null 2>&1; then
    alias cat="bat"
fi

# =============================================================================
# Mirror
# =============================================================================
export NODE_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/nodejs-release/
export GO111MODULE=on
export GOPROXY=https://goproxy.cn,direct

# =============================================================================
# Others
# =============================================================================
export GALLIUM_DRIVER=d3d12
man() {
    LESS_TERMCAP_md=$'\e[01;31m' \
    LESS_TERMCAP_me=$'\e[0m' \
    LESS_TERMCAP_se=$'\e[0m' \
    LESS_TERMCAP_so=$'\e[01;44;33m' \
    LESS_TERMCAP_ue=$'\e[0m' \
    LESS_TERMCAP_us=$'\e[01;32m' \
    command man "$@"
}

# fnm (Lazy Load)
FNM_PATH="$HOME/.local/share/fnm"
if [ -d "$FNM_PATH" ]; then
  export PATH="$FNM_PATH:$PATH"
  _load_fnm() {
    eval "$(fnm env --use-on-cd)"
    unset -f node npm npx fnm _load_fnm
  }
  node() { _load_fnm; node "$@"; }
  npm() { _load_fnm; npm "$@"; }
  npx() { _load_fnm; npx "$@"; }
  fnm() { _load_fnm; fnm "$@"; }
fi

[ -f "$HOME/.ghcup/env" ] && . "$HOME/.ghcup/env" # ghcup-env

# SDKMAN (Lazy Load)
export SDKMAN_DIR="$HOME/.sdkman"
if [[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]]; then
    sdk() {
        unset -f sdk
        source "$SDKMAN_DIR/bin/sdkman-init.sh"
        sdk "$@"
    }
fi

