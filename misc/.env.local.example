# ============================================================================
# .env.local — 本机私有配置模板
# 使用方法: cp .env.local.example .env.local 后按需修改
# 此文件不会被 git 追踪
# ============================================================================

# =============================================================================
# 代理设置（按需启用）
# =============================================================================
# export PROXY_HOST=127.0.0.1
# export PROXY_PORT=7890
# export PROXY_NO_PROXY="localhost,127.0.0.1,::1,*.local,10.0.0.0/8"

# =============================================================================
# WSL2 专有设置
# =============================================================================
# WSL2 下使用 D3D12 后端（GPU 加速）
# export GALLIUM_DRIVER=d3d12

# =============================================================================
# Conda / Anaconda 路径（按实际安装位置修改）
# =============================================================================
# 若使用 conda，取消注释并修改下方路径
# CONDA_PREFIX="/opt/anaconda3"
# __conda_setup="$("${CONDA_PREFIX}/bin/conda" 'shell.zsh' 'hook' 2>/dev/null)"
# if [ $? -eq 0 ]; then
#     eval "$__conda_setup"
# else
#     [ -f "${CONDA_PREFIX}/etc/profile.d/conda.sh" ] && \
#         . "${CONDA_PREFIX}/etc/profile.d/conda.sh" || \
#         export PATH="${CONDA_PREFIX}/bin:$PATH"
# fi
# unset __conda_setup

# =============================================================================
# 其他本机专有配置（示例）
# =============================================================================
# export WORK_EMAIL="you@company.com"
# export PERSONAL_EMAIL="you@example.com"
